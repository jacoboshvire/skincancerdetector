# Secret used to sign session JWTs. Generate with: openssl rand -base64 32
JWT_SECRET=ghjnmnbnbmbm.bnnb.

# Postgres connection string. In Vercel, add the "Postgres" (Neon-powered)
# storage integration to your project and this is injected automatically.
# For local development, copy the same value from the Vercel dashboard's
# Storage tab (or `vercel env pull .env.local`).
POSTGRES_URL=

# Set to "true" to require an emailed one-time code after password login.
# Currently defaults to disabled (false) for easier local development.
MFA_ENABLED=false

# SMTP settings for sending MFA one-time-code emails.
# If left unset, codes are printed to the server console instead (dev only).
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@skin-scan.local
